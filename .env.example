APP_ENV=dev
APP_NAME=ToolHub
HOST=127.0.0.1
PORT=8000
LOG_LEVEL=INFO

DATABASE_URL=postgresql://postgres:postgres@localhost:15432/toolhub
DATABASE_POOL_MIN_SIZE=1
DATABASE_POOL_MAX_SIZE=10
REDIS_URL=redis://localhost:6379/0

LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://api.example.com/v1
LLM_API_KEY=your_api_key
LLM_MODEL=your-model-name
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2

SANDBOX_PYTHON_IMAGE=python:3.12-alpine
SANDBOX_CLI_IMAGE=alpine/git:latest
SANDBOX_MEM_LIMIT=128m
SANDBOX_PIDS_LIMIT=64
SANDBOX_TIMEOUT_SECONDS=10
SANDBOX_NETWORK_DISABLED=true
CLI_POLICY_PATH=config/cli_policy.json

HTTP_TIMEOUT_SECONDS=10
HTTP_MAX_RETRIES=2
HTTP_MAX_REDIRECTS=3
HTTP_MAX_RESPONSE_BYTES=1048576
HTTP_ALLOWED_PORTS=80,443

WORKFLOW_SOFT_TIME_LIMIT_SECONDS=120
WORKFLOW_TIME_LIMIT_SECONDS=150
